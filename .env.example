# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=production
DEBUG=False

# Database (absolute path recommended in production)
SQLALCHEMY_DATABASE_URI=sqlite:////opt/ascend/ascend.db

# Server — Flask binds to 127.0.0.1 only; Nginx proxies from port 8716
HOST=127.0.0.1
PORT=8765

# CORS is handled by Nginx (same-origin) — only needed for local dev
CORS_ORIGIN=http://localhost:8716

# Security
MAX_CONTENT_LENGTH=6442450944  # 6GB request cap, allows 5GB file uploads with multipart overhead
