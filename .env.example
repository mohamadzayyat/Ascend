# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_ENV=production
DEBUG=False

# Database
SQLALCHEMY_DATABASE_URI=sqlite:////opt/cpanel/cpanel.db

# Server
HOST=0.0.0.0
PORT=8716         # Flask backend
FRONTEND_PORT=8717  # Next.js frontend
CORS_ORIGIN=http://localhost:8717  # Update to your domain in production

# GitHub (optional - for automatic updates)
GITHUB_TOKEN=

# Security
MAX_CONTENT_LENGTH=52428800  # 50MB

# Deployment Settings
DEPLOYMENT_DIR=/root/deployments
LOG_DIR=/root/deploy_logs
